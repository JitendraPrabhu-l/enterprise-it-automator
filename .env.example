# LLM backend: "groq" (free/fast, default), "anthropic", "watsonx", or "openrouter"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) — free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Anthropic (optional alternate backend)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# IBM watsonx.ai (alternate backend, LLM_PROVIDER=watsonx — langchain-ibm is
# a first-class installed dependency, ready to run once these are set).
# NOTE: provisioning a watsonx.ai project on IBM Cloud's Lite plan currently
# requires a credit card on file even though usage stays within the free
# tier — if that's blocking you, use LLM_PROVIDER=openrouter below instead,
# which needs only an API key.
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-3-8b-instruct

# OpenRouter (https://openrouter.ai/keys) — free tier, no card required,
# OpenAI-compatible API with access to several free-tier models. Credential-
# free fallback for when watsonx provisioning is blocked (see note above).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database — defaults to a local SQLite file under data/, no setup required.
# For Postgres: postgresql+asyncpg://user:password@localhost:5432/it_automator
DATABASE_URL=sqlite+aiosqlite:///./data/it_automator.db

# LangGraph checkpoint store — persists paused (awaiting-approval) agent runs
# across restarts. Separate SQLite file from DATABASE_URL by default
# (LangGraph owns this file's schema) — can instead be a Postgres connection
# string (postgresql://user:password@host:5432/it_automator, note: no
# "+asyncpg" here, this backend uses psycopg) to run AsyncPostgresSaver
# instead of AsyncSqliteSaver; see docker-compose.yml for a live example.
CHECKPOINT_DB_PATH=./data/it_automator_checkpoints.db

# Actions requiring human-in-the-loop approval before the MCP server executes
# them. Bare action names (not the namespaced gateway tool names like
# identity_disable_user) — is_sensitive() strips the domain-server prefix
# before checking, so this stays stable regardless of namespacing.
# create_user/grant_access are included (not just the destructive
# disable/revoke pair) so a prompt-injected or hallucinated planner output
# can't provision access for the wrong employee with nobody reviewing it.
SENSITIVE_ACTIONS=disable_user,enable_user,revoke_access,create_user,grant_access

# MCP transport: "stdio" (default, agent spawns the MCP server as a local
# subprocess, zero config) or "http" (connect to a standalone/remote MCP
# server over streamable-HTTP at MCP_SERVER_URL instead).
MCP_TRANSPORT=stdio
MCP_SERVER_URL=http://127.0.0.1:8765/mcp

# Host/port the MCP server binds to when run standalone with --transport http
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8765

# Required when running the MCP gateway with --transport http: FastMCP
# applies no authentication of its own on streamable-HTTP, so this bearer
# token is what stops any network client that can reach the server from
# calling sensitive tools directly. The agent sends it as an Authorization:
# Bearer header when MCP_TRANSPORT=http. Not needed for the default stdio
# transport (the spawned subprocess inherits trust from its parent process).
MCP_SERVER_TOKEN=

# DNS-rebinding protection (MCP spec 2025-11-25) for the --transport http
# gateway: comma-separated Host / Origin allowlists, enforced by the mcp
# SDK's own TransportSecurityMiddleware. Leave both blank for the local
# default (computed from MCP_SERVER_PORT above: 127.0.0.1:<port> and
# localhost:<port> for Host; no Origin allowed at all, since this
# project's real caller never sends an Origin header — only browsers do).
# Set these explicitly if you front the gateway with a real hostname.
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Shared secret required in the X-API-Key header for /tickets, /approvals, and
# /audit endpoints. Leave blank only for local, single-user demo runs — the
# server logs a warning at startup if unset.
API_KEY=

# Optional: a separate, low-privilege API key served UNAUTHENTICATED from
# GET /demo-key, so a public deployment's dashboard can auto-fill it for a
# stranger to try the app without you handing out a real credential. Seeded
# automatically as a STANDARD-role client with a low daily request cap (see
# app/api/main.py's _ensure_demo_guest_client) — it can submit tickets and
# see only tickets it itself filed, nothing else. Leave blank to disable
# (GET /demo-key then returns null and the dashboard behaves as before).
# Generate one the same way as API_KEY, e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(24))"` — use a
# DIFFERENT value than API_KEY, never reuse your admin key here.
DEMO_API_KEY=

# Optional: how often (in hours) the demo client's own tickets/approvals/
# audit entries are hard-deleted, so public demo traffic never accumulates
# alongside real data (see app/agent/demo_purge.py). Also hidden from your
# admin key's default /tickets and /approvals view in the meantime (pass
# ?include_demo=true to see them). No effect if DEMO_API_KEY is unset.
DEMO_DATA_RESET_HOURS=24

# OpenTelemetry: OTLP-HTTP endpoint to export agent/tool/LLM spans to (e.g. a
# local Jaeger instance, or a collector forwarding to Langfuse/LangSmith).
# Leave blank to keep tracing a no-op (the default, safe for local dev).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Stage 4.5 (scoped down) — approval SLA sweep. How long a sensitive approval
# may sit PENDING before the background sweep escalates it, and how often
# that sweep runs.
APPROVAL_SLA_MINUTES=60
SLA_SWEEP_INTERVAL_SECONDS=300
